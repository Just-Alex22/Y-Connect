<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/bg_view">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/bg_view"
        style="@style/Widget.MaterialComponents.Toolbar"
        android:elevation="0dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/quick_send_section"
            android:textAppearance="@style/TextAppearance.Yelena.Caption"
            android:layout_marginBottom="6dp"
            android:layout_marginStart="4dp"/>

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.Yelena.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <EditText
                        android:id="@+id/etQuickSend"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="@string/quick_send_hint"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_disabled"
                        android:textSize="14sp"
                        android:background="@null"
                        android:imeOptions="actionSend"
                        android:inputType="textMultiLine"
                        android:maxLines="3"/>
                    <ImageButton
                        android:id="@+id/btnQuickSend"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_send"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:tint="?attr/colorPrimary"
                        android:contentDescription="@string/send_to_pc"/>
                </LinearLayout>
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/bg_elevated"
                    android:layout_marginVertical="8dp"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPhoneClipToPC"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:text="@string/phone_clip_to_pc"
                    android:textSize="13sp"
                    style="@style/Widget.Yelena.Button.Outline"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/history_section"
            android:textAppearance="@style/TextAppearance.Yelena.Caption"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="6dp"
            android:layout_marginStart="4dp"/>

        <TextView
            android:id="@+id/tvEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/no_history"
            android:textColor="@color/text_disabled"
            android:gravity="center"
            android:padding="24dp"
            android:visibility="gone"/>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
            <LinearLayout
                android:id="@+id/historyList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>
        </ScrollView>

    </LinearLayout>
</LinearLayout>