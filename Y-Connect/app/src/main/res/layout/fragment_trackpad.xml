<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_view"
    android:padding="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/text_primary"
            android:contentDescription="@string/btn_back"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/keyboard_title"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLayoutQwerty"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="ABC"
            android:textSize="11sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            style="@style/Widget.Yelena.Button.Text"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLayoutSymbols"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="#@!"
            android:textSize="11sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            style="@style/Widget.Yelena.Button.Text"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLayoutFn"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="FN"
            android:textSize="11sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            style="@style/Widget.Yelena.Button.Text"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCtrl"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="Ctrl"
            android:textSize="11sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:layout_marginEnd="3dp"
            style="@style/Widget.Yelena.Button.Outline"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnShift"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="Shift"
            android:textSize="11sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:layout_marginEnd="3dp"
            style="@style/Widget.Yelena.Button.Outline"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAlt"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="Alt"
            android:textSize="11sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:layout_marginEnd="3dp"
            style="@style/Widget.Yelena.Button.Outline"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSuper"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="Super"
            android:textSize="11sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            style="@style/Widget.Yelena.Button.Outline"/>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/keyboardContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"/>

</LinearLayout>